{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "site-vendas",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "site", "-p", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "loja-flask",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-X", "utf8", "-c", "import wsgi; wsgi.app.run(host='127.0.0.1', port=8000)"],
      "port": 8000
    }
  ]
}
