# ═══ CHAVES OBRIGATÓRIAS ═══
ANTHROPIC_API_KEY=sk-ant-...
MP_ACCESS_TOKEN=APP_USR-...

# ═══ SEGURANÇA (defina no Railway!) ═══
ADMIN_USER=admin
ADMIN_PASS=                 # OBRIGATÓRIO — senha forte do painel admin
JWT_SECRET=                 # opcional — se vazio, deriva de ADMIN_PASS
MP_WEBHOOK_SECRET=          # opcional — valida assinatura do webhook MP

# ═══ BANCO DE DADOS ═══
